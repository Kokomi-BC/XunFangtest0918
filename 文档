查询ServiceImpl:

/**
     * 查询产品信息列表
     * 
     * @return 产品信息
     */
    @Override
    public List<XfVersionProduct> selectXfProductList(QueryProductDTO queryProductDTO, HttpServletRequest request) throws Exception {
        String url = DMEUtil.executeApiUrl+"/XfProduct01/find/" + request.getParameter("pageSize") + "/" + request.getParameter("pageNum");

        JSONObject paramsJson = new JSONObject();
        JSONObject params = new JSONObject();
        params.put("characterSet", "UTF8");
        params.put("decrypt", false);
        params.put("isPresentAll", true);
        params.put("presentFields", Arrays.asList(
                "lifecycleState", "lifecycleTemplate", "lifecyclePhaseList", "reserved"
        ));

        // 只查最新 + 按更新时间倒序
        params.put("orderBy", "lastUpdateTime");
        params.put("sort", "DESC");
        // 是否需要总数：与他一致可设为 false（不影响返回条数）
        params.put("isNeedTotal", false);
        // 公共参数，保留
        params.put("publicData", "INCLUDE_PUBLIC_DATA");

        // ===== 过滤条件 =====
        JSONObject filter = new JSONObject();
        JSONArray conditions = new JSONArray();

        // latest = true 只返回最新版本（关键条件）
        {
            JSONObject latestCond = new JSONObject();
            latestCond.put("conditionName", "latest");
            latestCond.put("operator", "=");
            JSONArray val = new JSONArray();
            val.add(true); // 注意：布尔值，不要加引号
            latestCond.put("conditionValues", val);
            conditions.add(latestCond);
        }

        // partName like
        if (queryProductDTO.getProductName() != null && !queryProductDTO.getProductName().isEmpty()) {
            JSONObject c = new JSONObject();
            c.put("conditionName", "productName");
            JSONArray v = new JSONArray();
            v.add(queryProductDTO.getProductName());
            c.put("conditionValues", v);
            c.put("ignoreStr", false);
            c.put("multi", false);
            c.put("operator", "like");
            conditions.add(c);
        }

        // productFamily like
        if (queryProductDTO.getProductFamily() != null && !queryProductDTO.getProductFamily().isEmpty()) {
            JSONObject c = new JSONObject();
            c.put("conditionName", "productFamily");
            JSONArray v = new JSONArray();
            v.add(queryProductDTO.getProductFamily());
            c.put("conditionValues", v);
            c.put("ignoreStr", false);
            c.put("multi", false);
            c.put("operator", "like");
            conditions.add(c);
        }

        // category =
        if (queryProductDTO.getCategory() != null && !queryProductDTO.getCategory().isEmpty()) {
            JSONObject c = new JSONObject();
            c.put("conditionName", "category");
            JSONArray v = new JSONArray();
            v.add(queryProductDTO.getCategory());
            c.put("conditionValues", v);
            c.put("ignoreStr", false);
            c.put("multi", false);
            c.put("operator", "=");
            conditions.add(c);
        }

        filter.put("conditions", conditions);
        filter.put("ignoreStr", false);
        filter.put("joiner", "and");
        filter.put("multi", false);

        // 把 filter 放进 params
        params.put("filter", filter);
        paramsJson.put("params", params);

        // 发起调用
        DMEResponse<XfVersionProduct> response = dmeClient.post(
                url,
                paramsJson,
                new TypeReference<DMEResponse<XfVersionProduct>>() {}
        );
        // 组装分页返回
        List<XfVersionProduct> list = response.getData();
        return list;
    }
